# LTspice simulation outputs — ignore at all directory levels
# Simulation result files
*.log
*.raw
*.raw.*
*.op.raw
*.fft
*.ft0
*.plt
*.out
*.net

# LTspice schematic backups/temp
*.asc~

# Generic backup/temp files
*~
*.bak
*.tmp
*.swp

# OS/editor junk
.DS_Store
Thumbs.db

# KiCad temporary and lock files
*.lck
~*.lck

# KiCad local user settings (remembers zoom levels, active layers, etc.)
*.kicad_prl

# KiCad auto-save and backup files
*-save.kicad_pcb
*-save.kicad_sch
*-bak.kicad_pcb
*-bak.kicad_sch
_autosave-*

# VS Code local history extension
.history/
.vscode/
